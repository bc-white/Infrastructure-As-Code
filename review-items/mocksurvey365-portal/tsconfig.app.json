{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
  "@/*": ["./src/*"],
  "@/components/*": ["./src/components/*"],
  "@/utils/*": ["./src/utils/*"],
  "@/ui/*": ["./src/components/ui/*"],
  "@/lib/*": ["./src/lib/*"],
  "@/hooks/*": ["./src/hooks/*"],
  "@/store/*": ["./src/store/*"],
  "@/assets/*": ["./src/assets/*"],
  "@/pages/*": ["./src/pages/*"],
  "@/api/*": ["./src/api/*"]
    }
  },
  "include": ["src"]
}
