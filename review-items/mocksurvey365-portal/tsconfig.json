{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
  "@/*": ["./src/*"],
  "@/components/*": ["./src/components/*"],
  "@/utils/*": ["./src/utils/*"],
  "@/ui/*": ["./src/components/ui/*"],
  "@/lib/*": ["./src/lib/*"],
  "@/hooks/*": ["./src/hooks/*"],
  "@/store/*": ["./src/store/*"],
  "@/assets/*": ["./src/assets/*"],
  "@/pages/*": ["./src/pages/*"],
  "@/api/*": ["./src/api/*"]
    },
     "strict": true,
    "forceConsistentCasingInFileNames": true
  },
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
