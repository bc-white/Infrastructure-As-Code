# API Base URL
VITE_API_BASE_URL=https://apistaging.mocksurvey365.com/api/v1/

# Firebase configuration (client & service worker)
# You can use either plain FIREBASE_* or VITE_FIREBASE_* keys.
# VITE_* will be available in your app code via import.meta.env.

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Alternatively, Vite-prefixed keys
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Auth0 configuration
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id

# Error Reporting
VITE_ERROR_REPORT_EMAIL=richard@mocksurvey365.com
